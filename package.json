{
  "name": "slack-beaver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.cjs",
    "uat:first": "node scripts/uat-start.cjs first",
    "uat:resume": "node scripts/uat-start.cjs resume",
    "uat:reset": "node scripts/uat-start.cjs reset",
    "predev": "npm run check:node",
    "dev": "tsx src/index.ts",
    "precenter:dev": "npm run check:node",
    "center:dev": "tsx src/center-server/index.ts",
    "precenter:tasks:list": "npm run check:node",
    "center:tasks:list": "tsx src/cli/centerCli.ts tasks:list",
    "precenter:tasks:create": "npm run check:node",
    "center:tasks:create": "tsx src/cli/centerCli.ts tasks:create",
    "precenter:tasks:update": "npm run check:node",
    "center:tasks:update": "tsx src/cli/centerCli.ts tasks:update",
    "precenter:agents:register": "npm run check:node",
    "center:agents:register": "tsx src/cli/centerCli.ts agents:register",
    "precenter:agent-tasks:list": "npm run check:node",
    "center:agent-tasks:list": "tsx src/cli/centerCli.ts agent-tasks:list",
    "precenter:agent-tasks:create": "npm run check:node",
    "center:agent-tasks:create": "tsx src/cli/centerCli.ts agent-tasks:create",
    "precenter:agent-tasks:claim": "npm run check:node",
    "center:agent-tasks:claim": "tsx src/cli/centerCli.ts agent-tasks:claim",
    "preagent:worker": "npm run check:node",
    "agent:worker": "tsx src/agent/agentWorkerCli.ts",
    "preagent:folders:add": "npm run check:node",
    "agent:folders:add": "tsx src/cli/localCli.ts folders:add",
    "preagent:folders:list": "npm run check:node",
    "agent:folders:list": "tsx src/cli/localCli.ts folders:list",
    "preagent:folders:remove": "npm run check:node",
    "agent:folders:remove": "tsx src/cli/localCli.ts folders:remove",
    "preagent:memory:reset": "npm run check:node",
    "agent:memory:reset": "tsx src/cli/localCli.ts memory:reset",
    "preagent:secrets:set-openai": "npm run check:node",
    "agent:secrets:set-openai": "tsx src/cli/localCli.ts secrets:set-openai",
    "preagent:models:list": "npm run check:node",
    "agent:models:list": "tsx src/cli/localCli.ts models:list",
    "preagent:models:current": "npm run check:node",
    "agent:models:current": "tsx src/cli/localCli.ts models:current",
    "preagent:models:set": "npm run check:node",
    "agent:models:set": "tsx src/cli/localCli.ts models:set",
    "preagent:google:login": "npm run check:node",
    "agent:google:login": "tsx src/cli/localCli.ts google:login",
    "preagent:google:status": "npm run check:node",
    "agent:google:status": "tsx src/cli/localCli.ts google:status",
    "preagent:google:logout": "npm run check:node",
    "agent:google:logout": "tsx src/cli/localCli.ts google:logout",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run check:node",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "pretypecheck": "npm run check:node",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run check:node",
    "test": "vitest run",
    "preverify": "npm run check:node",
    "verify": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@slack/bolt": "^3.21.2",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.7",
    "openai": "^6.45.0",
    "pdfjs-dist": "^5.4.394"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
